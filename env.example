# ── Om Clinic Backend — Environment Variables ──────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.

# MongoDB Atlas connection string
MONGODB_URI=mongodb://Clinic:yourpassword@ac-xxxx.mongodb.net:27017,...

# Server port (optional — defaults to 3000)
PORT=3000

# Admin password — change this to something strong, only you know it!
# This is the ONLY place the password lives. Never in source code.
ADMIN_PASSWORD=ChangeThisToSomethingStrong123!
